{
  "name": "book-in-monorepo",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- turbo run dev",
    "build": "dotenv -e .env.local -- turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify": "dotenv -e .env.local -- npx -y tsx packages/db/src/verify.ts",
    "db:migrate": "dotenv -e .env.local -- npx -y tsx packages/db/src/migrate.ts",
    "db:generate": "dotenv -e .env.local -- pnpm --filter @book-in/db run prisma:generate"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.7.1",
    "turbo": "^1.10.0",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "bcryptjs": "^3.0.3",
    "next-auth": "5.0.0-beta.31",
    "stripe": "^22.2.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.10",
      "@types/react-dom": "^19.0.4"
    }
  }
}

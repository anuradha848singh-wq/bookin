# ═══════════════════════════════════════════════
# SECTION 1: DATABASE
# ═══════════════════════════════════════════════
DATABASE_URL="postgresql://platform_admin:password@localhost:5433/platform_global?schema=global&connection_limit=5"
DATABASE_DIRECT_URL="postgresql://platform_admin:password@localhost:5432/platform_global?schema=global"
# ^ DIRECT_URL bypasses PgBouncer — used for migrations ONLY

# ═══════════════════════════════════════════════
# SECTION 2: REDIS
# ═══════════════════════════════════════════════
REDIS_URL="redis://:local_redis_password@localhost:6379"
REDIS_SESSION_PREFIX="session:"
REDIS_RATE_LIMIT_PREFIX="ratelimit:"

# ═══════════════════════════════════════════════
# SECTION 3: AUTH
# ═══════════════════════════════════════════════
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="GENERATE_WITH_openssl_rand_-base64_32"
JWT_ACCESS_SECRET="GENERATE_WITH_openssl_rand_-base64_64"
JWT_REFRESH_SECRET="GENERATE_WITH_openssl_rand_-base64_64"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ═══════════════════════════════════════════════
# SECTION 4: STRIPE
# ═══════════════════════════════════════════════
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PLATFORM_FEE_PERCENT=2.5

# ═══════════════════════════════════════════════
# SECTION 5: EMAIL (RESEND)
# ═══════════════════════════════════════════════
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourplatform.com"
EMAIL_REPLY_TO="support@yourplatform.com"

# ═══════════════════════════════════════════════
# SECTION 6: SMS (TWILIO)
# ═══════════════════════════════════════════════
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# ═══════════════════════════════════════════════
# SECTION 7: AWS / STORAGE
# ═══════════════════════════════════════════════
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
AWS_S3_BUCKET="platform-uploads-prod"
AWS_CLOUDFRONT_URL="https://cdn.yourplatform.com"

# ═══════════════════════════════════════════════
# SECTION 8: GOOGLE OAUTH & CALENDAR
# ═══════════════════════════════════════════════
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/v1/integrations/google/callback"

# ═══════════════════════════════════════════════
# SECTION 9: PLATFORM SETTINGS
# ═══════════════════════════════════════════════
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="YourPlatform"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NODE_ENV="development"
LOG_LEVEL="debug"

# ═══════════════════════════════════════════════
# SECTION 10: MONITORING (Phase 15)
# ═══════════════════════════════════════════════
SENTRY_DSN="https://...@sentry.io/..."
SENTRY_AUTH_TOKEN="..."
DATADOG_API_KEY="..."

# ═══════════════════════════════════════════════
# SECTION 11: AI (Phase 16)
# ═══════════════════════════════════════════════
ANTHROPIC_API_KEY="sk-ant-..."
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="GENERATE_STRONG_SECRET"

# ═══════════════════════════════════════════════
# SECTION 12: ZOOM (Phase 13)
# ═══════════════════════════════════════════════
ZOOM_CLIENT_ID="..."
ZOOM_CLIENT_SECRET="..."
ZOOM_REDIRECT_URI="http://localhost:3000/api/v1/integrations/zoom/callback"
